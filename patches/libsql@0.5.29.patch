@@ -23,6 +23,11 @@ function requireNative() {
   if (target === "linux-arm-gnueabihf" && familySync() == MUSL) {
       target = "linux-arm-musleabihf";
   }
+  // canvazz patch: a literal require so `bun build --compile` can statically
+  // bundle the prebuilt addon into the single-file binary (computed-string
+  // requires are invisible to the bundler). Other platforms keep the dynamic
+  // path below, so dev/CI on Linux is unaffected.
+  if (target === "darwin-arm64") return require("@libsql/darwin-arm64");
   return require(`@libsql/${target}`);
 }
 
