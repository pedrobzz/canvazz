{
  "name": "canvazz",
  "version": "0.3.0",
  "description": "Local-first, AI-first design editor: a DOM-native canvas with a built-in MCP server",
  "license": "MIT",
  "author": "pedrobzz <pedro@pedrobzz.dev>",
  "homepage": "https://github.com/pedrobzz/canvazz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedrobzz/canvazz.git"
  },
  "bugs": {
    "url": "https://github.com/pedrobzz/canvazz/issues"
  },
  "keywords": [
    "design-editor",
    "design-tool",
    "canvas",
    "html",
    "css",
    "mcp",
    "model-context-protocol",
    "ai",
    "local-first",
    "react",
    "tanstack",
    "design-to-code"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.2.0"
  },
  "bin": {
    "canvazz": "bin/canvazz.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 47823",
    "build": "vite build",
    "start": "node bin/canvazz.mjs",
    "prepublishOnly": "vite build",
    "preview": "vite preview",
    "generate-routes": "tsr generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "build:binary": "bun run build && bun tools/gen-embedded-assets.mjs && bun tools/build-binary.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tailwindcss/browser": "^4.3.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/history": "^1.162.0",
    "@tanstack/query-db-collection": "^1.0.40",
    "@tanstack/react-db": "^0.1.86",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-core": "^1.171.13",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "h3-v2": "npm:h3@2.0.1-rc.20",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "seroval": "^1.5.4",
    "sf-symbols-lib": "^2.0.1",
    "srvx": "^0.11.16",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "trustedDependencies": [
    "esbuild",
    "lightningcss"
  ],
  "patchedDependencies": {
    "libsql@0.5.29": "patches/libsql@0.5.29.patch"
  },
  "optionalDependencies": {
    "@libsql/darwin-arm64": "0.5.29"
  }
}